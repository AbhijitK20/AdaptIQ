# Copy this file to `.env.local` and fill in real values before running the app.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional Supabase / local auth helpers
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# Email reminders
RESEND_API_KEY=your_resend_api_key
REMINDER_FROM_EMAIL=your_verified_sender@example.com
REMINDER_APP_URL=http://localhost:3000
REMINDER_JOB_SECRET=your_reminder_job_secret

# Hindsight memory / recovery
HINDSIGHT_API_URL=https://api.hindsight.vectorize.io
HINDSIGHT_API_KEY=your_hindsight_api_key
HINDSIGHT_BANK_PREFIX=adaptiq-user

# Optional Postgres connection values used by scripts and integrations
POSTGRES_DATABASE=postgres
POSTGRES_HOST=your-postgres-host
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_PRISMA_URL=postgresql://postgres:your_postgres_password@your-host:6543/postgres?pgbouncer=true
POSTGRES_URL=postgres://postgres:your_postgres_password@your-host:6543/postgres?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://postgres:your_postgres_password@your-host:5432/postgres?sslmode=require
POSTGRES_USER=postgres
